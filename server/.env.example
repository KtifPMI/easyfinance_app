PORT=4000

# Get these by registering an app at https://easyfinance.ru/my/register-app/
EASYFINANCE_APP_ID=your_app_id_here
EASYFINANCE_SECRET_KEY=your_secret_key_here

# Where the mobile app should redirect back to after the user grants access
# (deep link scheme registered in app.json -> "scheme")
OAUTH_REDIRECT_URI=easyfinanceapp://oauth-callback
